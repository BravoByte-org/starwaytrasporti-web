# BravoByte private packages — GitHub Packages for @bravobyte-org.
# NODE_AUTH_TOKEN must be exported in the shell that runs pnpm (not only set).
# Sourcing a file? Use: export NODE_AUTH_TOKEN=…  or  set -a && source ~/.config/… && set +a
# CI: https://docs.github.com/en/packages/working-with-a-github-packages-registry/working-with-the-npm-registry
@bravobyte-org:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
engine-strict=true
